# ─────────────────────────────────────────────────────────────────────────────
# LockUp — Environment Variable Template
# Copy this file to .env.local and fill in the values for your environment.
# NEVER commit .env.local or any file containing real secrets to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI / LLM ─────────────────────────────────────────────────────────────────

# Anthropic Claude API key — used by /api/ai/analyze for real AI-powered analysis.
# Get yours at: https://console.anthropic.com/
# Leave empty to run in demo/mock mode (safe for local development).
ANTHROPIC_API_KEY=

# ── Authentication ────────────────────────────────────────────────────────────

# Secret key used to validate API requests to protected routes (/api/scan, /api/ai).
# Generate a strong random value, e.g.: openssl rand -hex 32
# If left empty the middleware will allow all requests (dev-only behaviour).
LOCKUP_API_KEY=

# NextAuth secret — required if you add NextAuth.js for user authentication.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string for persistent scan data.
# Example: postgresql://user:password@localhost:5432/lockup
DATABASE_URL=

# ── Integrations ──────────────────────────────────────────────────────────────

# GitHub App credentials — used to open PRs with auto-generated fixes.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=

# Slack webhook URL — used for critical vulnerability notifications.
SLACK_WEBHOOK_URL=

# ── Feature Flags ─────────────────────────────────────────────────────────────

# Set to "true" to enable real scan orchestration (vs mock responses).
ENABLE_REAL_SCANS=false

# Set to "true" to enable AI-powered auto-fix PR creation.
ENABLE_AUTO_FIX=false

# ── Telemetry / Observability ─────────────────────────────────────────────────

# Vercel Analytics is enabled automatically on Vercel deployments.
# Set to "false" to opt out of telemetry in self-hosted deployments.
NEXT_PUBLIC_ANALYTICS_ENABLED=true

# Sentry DSN for error tracking (optional).
SENTRY_DSN=

# ── Deployment ────────────────────────────────────────────────────────────────

# Set automatically by Vercel; used by the health endpoint.
VERCEL_ENV=development
NODE_ENV=development
